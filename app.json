{
  "expo": {
    "name": "Oryn",
    "slug": "oryn-expense-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.agit.oryn",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to scan receipts",
        "NSPhotoLibraryUsageDescription": "Used to attach receipt photos",
        "NSFaceIDUsageDescription": "Used to secure your Oryn data",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.agit.oryn"
    },
    "plugins": [
      "expo-camera",
      "expo-image-picker"
    ],
    "scheme": "oryn",
    "extra": {
      "eas": {
        "projectId": "d81ab392-b84d-4945-b50c-06a9fccffc20"
      }
    }
  }
}
